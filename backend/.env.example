NODE_ENV=development
PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/bybs_lms
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
JSON_BODY_LIMIT=2mb
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=65000
HEADERS_TIMEOUT_MS=66000
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=1500
MUTATION_RATE_LIMIT_WINDOW_MS=60000
MUTATION_RATE_LIMIT_MAX=180
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
CLIENT_ADMIN_URL=http://localhost:5173
CLIENT_MENTOR_URL=http://localhost:5174
CLIENT_STUDENT_URL=http://localhost:5175
CERTIFICATE_VERIFY_BASE_URL=http://localhost:5175
PUBLIC_API_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=bybs-lms/uploads
REQUIRE_COMPRESSED_UPLOADS=true
EMAIL_LOGO_URL=
PUBLIC_WEBSITE_URL=
MENTOR_WHATSAPP_URL=
MENTOR_CHANNEL_URL=
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_LINKEDIN_URL=
SOCIAL_YOUTUBE_URL=
UPLOAD_DIR=uploads
ADMIN_ALERTS_ENABLED=true
ADMIN_ALERT_EMAILS=
ADMIN_ALERT_COOLDOWN_MS=600000
SLOW_REQUEST_THRESHOLD_MS=3000
EMAIL_FROM=BYBS LMS <alerts@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SEED_SUPER_ADMIN_ON_START=false
MONGO_MEMORY_DOWNLOAD_DIR=/private/tmp/bybs-mongodb-binaries
MONGO_MEMORY_DB_PATH=/private/tmp/bybs-lms-mongodb
MONGO_MEMORY_PORT=27018
RESEND_API_KEY=
SUPER_ADMIN_NAME=BYBS Super Admin
SUPER_ADMIN_EMAIL=admin@bybs.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
